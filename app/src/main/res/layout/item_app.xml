<?xml version="1.0" encoding="utf-8"?>
<!-- Layout for app list items. Generated by AI. -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/colorCardBg"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <ImageView
            android:id="@+id/ivAppIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="12dp"
            android:contentDescription="@null"
            tools:src="@android:drawable/sym_def_app_icon"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="App Name"/>

                <TextView
                    android:id="@+id/tvSystemBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/system_app_badge"
                    android:textColor="@color/colorPrimary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_system_badge"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/tvPinnedBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pinned_app_badge"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    app:backgroundTint="@color/colorAccentBright"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvPackageName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                tools:text="com.example.app"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpen"
                android:layout_width="72dp"
                android:layout_height="34dp"
                android:text="@string/btn_open"
                android:textSize="12sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp"
                app:backgroundTint="@color/colorBtnOpen"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInfo"
                android:layout_width="72dp"
                android:layout_height="34dp"
                android:text="@string/btn_info"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp"
                app:backgroundTint="@color/colorBtnInfo"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
